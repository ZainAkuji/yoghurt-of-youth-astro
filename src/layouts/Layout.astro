---
import "../styles/global.css";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.astro";
import CartDrawer from "../components/CartDrawer.tsx";

interface Props {
  title: string;
  description: string;
  productSchema?: object;
  transparentHero?: boolean;
}

const { title, description, productSchema, transparentHero } = Astro.props;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Yoghurt of Youth",
  "url": "https://yoghurtofyouth.co.uk",
  "logo": "https://yoghurtofyouth.co.uk/logo.png",
  "description": "Fresh-fermented live L. reuteri probiotic yoghurt, lactose-free and made in small batches in Blackburn with UK-wide chilled next-day delivery.",
  "email": "support@yoghurtofyouth.co.uk",
  "telephone": "+44-7756-231844",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Blackburn",
    "addressRegion": "Lancashire",
    "addressCountry": "GB"
  },
  "sameAs": [
    "https://www.instagram.com/yoghurtofyouth"
  ]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Yoghurt of Youth",
  "url": "https://yoghurtofyouth.co.uk"
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Per-page SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph (social sharing) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://yoghurtofyouth.co.uk/og-image.png" />

    <meta name="twitter:card" content="summary_large_image" />

	<!-- Meta Pixel -->
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '2464598340648858');
      fbq('track', 'PageView');
    </script>

	<!-- Klaviyo onsite -->
    <script is:inline async type="text/javascript" src="https://static.klaviyo.com/onsite/js/VxBsdc/klaviyo.js"></script>

	<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
	{productSchema && <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />}
  </head>
  <body class="min-h-screen bg-gradient-to-b from-white to-slate-50 text-slate-800">
    <!-- Announcement banner (sticky, above header) -->
    <div class="yoy-banner">
      <div class="yoy-banner-track">
        <span class="yoy-banner-content">
          <span>7 for the price of 6</span><span class="dot">·</span>
          <span>Sign up for 10% off your first order</span><span class="dot">·</span>
          <span>Subscribe &amp; save 10%</span><span class="dot">·</span>
          <span>Chilled next-day delivery £4.95</span><span class="dot">·</span>
          <span><span class="stars">★★★★★</span> 5.0 on Google</span><span class="dot">·</span>
        </span>
        <span class="yoy-banner-content" aria-hidden="true">
          <span>7 for the price of 6</span><span class="dot">·</span>
          <span>Sign up for 10% off your first order</span><span class="dot">·</span>
          <span>Subscribe &amp; save 10%</span><span class="dot">·</span>
          <span>Chilled next-day delivery £4.95</span><span class="dot">·</span>
          <span><span class="stars">★★★★★</span> 5.0 on Google</span><span class="dot">·</span>
        </span>
        <span class="yoy-banner-content" aria-hidden="true">
          <span>7 for the price of 6</span><span class="dot">·</span>
          <span>Sign up for 10% off your first order</span><span class="dot">·</span>
          <span>Subscribe &amp; save 10%</span><span class="dot">·</span>
          <span>Chilled next-day delivery £4.95</span><span class="dot">·</span>
          <span><span class="stars">★★★★★</span> 5.0 on Google</span><span class="dot">·</span>
        </span>
        <span class="yoy-banner-content" aria-hidden="true">
          <span>7 for the price of 6</span><span class="dot">·</span>
          <span>Sign up for 10% off your first order</span><span class="dot">·</span>
          <span>Subscribe &amp; save 10%</span><span class="dot">·</span>
          <span>Chilled next-day delivery £4.95</span><span class="dot">·</span>
          <span><span class="stars">★★★★★</span> 5.0 on Google</span><span class="dot">·</span>
        </span>
      </div>
    </div>

    <style>
      .yoy-banner {
        position: sticky;
        top: 0;
        z-index: 60; /* above the header (z-50) */
        height: 28px;
        display: flex;
        align-items: center;
        width: 100%;
        background: #000;
        color: #fff;
        overflow: hidden;
        white-space: nowrap;
        font-size: 12px;
        line-height: 1;
      }
      .yoy-banner-track {
        display: inline-flex;
        width: max-content;
        animation: yoy-scroll 60s linear infinite;
      }
      .yoy-banner:hover .yoy-banner-track { animation-play-state: paused; }
      .yoy-banner-content {
        display: inline-flex;
        align-items: center;
        gap: 16px;
        padding-right: 16px;
      }
      .yoy-banner .dot { opacity: 0.5; }
      .yoy-banner .stars { color: #fcd34d; }
      @keyframes yoy-scroll {
        from { transform: translateX(0); }
        to { transform: translateX(-50%); }
      }
      @media (prefers-reduced-motion: reduce) {
        .yoy-banner-track { animation: none; }
        .yoy-banner { overflow-x: auto; }
      }
    </style>

    <!-- Header is interactive (scroll-shrink), so it runs as a React island -->
    <Header client:load brand="Yoghurt of Youth" transparentHero={transparentHero} />
    <CartDrawer client:load />

    <!-- Each page's unique content drops in here -->
    <slot />

    <Footer />
  </body>
</html>