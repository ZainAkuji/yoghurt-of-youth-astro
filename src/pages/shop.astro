---
import Layout from "../layouts/Layout.astro";
import Shop from "../components/Shop.tsx";

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "L. reuteri Probiotic Yoghurt",
  "image": "https://yoghurtofyouth.co.uk/spctrl.webp",
  "description": "Fresh-fermented live L. reuteri probiotic yoghurt. Lactose-free, with over one trillion live cultures per bottle. Made in small batches in Blackburn.",
  "brand": {
    "@type": "Brand",
    "name": "Yoghurt of Youth"
  },
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "GBP",
    "lowPrice": "2.80",
    "highPrice": "2.90",
    "availability": "https://schema.org/InStock",
    "url": "https://yoghurtofyouth.co.uk/shop"
  }
};
---

<Layout
  title="Buy L. reuteri Yoghurt Online UK | Yoghurt of Youth"
  description="Order live L. reuteri probiotic yoghurt online, pick your flavours or subscribe weekly. Lactose-free, one trillion CFU, chilled next-day UK delivery."
  productSchema={productSchema}
>
  <Shop client:load />
</Layout>