---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="L. reuteri Probiotic Yoghurt UK | Yoghurt of Youth"
  description="Buy live L. reuteri probiotic yoghurt in the UK. Fresh-fermented and lactose-free with one trillion CFU per bottle, plus chilled next-day delivery."
>
  <!-- ===== HERO ===== -->
  <section
    id="hero"
    class="relative w-full overflow-hidden bg-black"
    style="aspect-ratio: 16 / 9;"
  >
    <img
      class="absolute inset-0 w-full h-full object-cover"
      src="/hero_bg.webp"
      alt=""
    />

    <div class="absolute inset-0 bg-black/25"></div>

    <!-- Slogan (kept as a visual element, NOT the page h1) -->
    <div class="absolute top-3 left-4 sm:top-6 sm:left-8 z-20">
      <p class="text-white font-mono font-bold text-xl sm:text-3xl md:text-6xl leading-tight drop-shadow-[0_2px_6px_rgba(0,0,0,0.5)]">
        By L reuteri.
      </p>
    </div>

    <div class="relative z-10 flex items-center justify-center h-full">
      <img
        src="/logo_inverted_transparent.png"
        alt="Yoghurt of Youth logo"
        class="w-auto h-24 sm:h-36 md:h-56 lg:h-72 max-w-[88%] object-contain"
      />
    </div>
  </section>

  <!-- ===== PRODUCT LINES (PRCXN / SPCTRL) ===== -->
  <section id="products" class="scroll-mt-32 md:scroll-mt-24 w-full">
    <div class="mx-auto grid grid-cols-1 md:grid-cols-2 gap-0 w-full">
      <!-- PRCXN -->
      <article class="relative aspect-[3/2] w-full overflow-hidden">
        <img src="/prcxn.webp" alt="PRCXN — targeted L. reuteri DSM 17648 yoghurt" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black/40"></div>
        <div class="relative z-10 h-full flex flex-col justify-between p-6">
          <div>
            <p class="text-sm uppercase tracking-[0.2em] text-white mb-1">Targeted</p>
            <img src="/prcxn_logo.png" alt="PRCXN" class="w-[60%] object-contain drop-shadow-lg" />
            <p class="mt-2 text-sm text-white max-w-md leading-relaxed">
              Yoghurt fermented by <em>L. reuteri</em> DSM 17648.<br />
              1 trillion CFU.<br />
              Targets <em>H. pylori</em>.<br />
              Alternated with SPCTRL for full gut restoration.<br />
              No added sweeteners.<br />
              Lactose-free.<br />
              250ml.
            </p>
          </div>
        </div>
      </article>

      <!-- SPCTRL -->
      <article class="relative aspect-[3/2] w-full overflow-hidden">
        <img src="/spctrl.webp" alt="SPCTRL — broad-acting L. reuteri DSM 17938 yoghurt" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black/40"></div>
        <div class="relative z-10 h-full flex flex-col justify-between p-6">
          <div>
            <p class="text-sm uppercase tracking-[0.2em] text-white mb-1">Broad-acting</p>
            <img src="/spctrl_logo.png" alt="SPCTRL" class="w-[60%] object-contain drop-shadow-lg" />
            <p class="mt-2 text-sm text-white max-w-md leading-relaxed">
              Yoghurt fermented by <em>L. reuteri</em> DSM 17938.<br />
              1 trillion CFU.<br />
              Targets pathogens including <em>Candida</em>.<br />
              Alternated with PRCXN for full gut restoration.<br />
              No added sweeteners.<br />
              Lactose-free.<br />
              250ml.
            </p>
          </div>
        </div>
      </article>
    </div>

  <!-- ===== SEO INTRO ===== -->
  <section
    id="intro"
    class="relative scroll-mt-32 md:scroll-mt-24 text-white py-12"
    style="background-image: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.65)), url('/about_bg.webp'); background-size: cover; background-position: 50% center; background-repeat: no-repeat;"
  >
    <div class="max-w-3xl px-8 mx-auto">
      <h1 class="text-2xl md:text-3xl font-bold text-white">
        Live <em>L. reuteri</em> Probiotic Yoghurt for Gut Health
      </h1>

      <p class="mt-4 text-white leading-relaxed">
        Yoghurt of Youth is a lactose-free probiotic yoghurt
        fermented by <em>Lactobacillus reuteri</em>, with over
        <strong>one trillion CFU</strong> per 250&nbsp;ml bottle.
		Delivered chilled across the UK, it is a
        simple, natural, excellent way to support your gut health
		on a daily basis.
      </p>

      <p class="mt-3 text-white leading-relaxed">
        We craft two well-researched <em>L. reuteri</em> strains and alternate
        them week by week. The strains work together to deliver amazing results.
		No added sweeteners. Completely lactose-free.
      </p>

      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href="/about" class="rounded-2xl bg-white text-black px-6 py-2.5 text-sm font-semibold hover:bg-amber-300 transition">
          Learn More
        </a>
        <a href="/shop" class="rounded-2xl bg-white text-black px-6 py-2.5 text-sm font-semibold hover:bg-amber-300 transition">
          Shop Now
        </a>
      </div>
    </div>
  </section>
</Layout>