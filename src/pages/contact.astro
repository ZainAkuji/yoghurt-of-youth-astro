---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact Us | Yoghurt of Youth"
  description="Get in touch with Yoghurt of Youth. Email or call us for product advice, order support, or any questions about our live L. reuteri probiotic yoghurt."
>
  <section
    id="contact"
    class="relative scroll-mt-32 md:scroll-mt-24 bg-white text-slate-800 py-12"
  >
    <div class="max-w-3xl mx-auto px-8">
      <h1 class="text-2xl md:text-3xl font-bold text-slate-900">
        Contact Us
      </h1>

      <p class="mt-4 text-slate-700 text-sm leading-relaxed">
        Have a question about our yoghurt or your order? We're always happy to help. Get in touch and we'll get back to
        you as soon as we can.
      </p>

      <div class="mt-6 space-y-2 text-slate-700 text-sm">
        <p>
          📧 Email:
          <a href="mailto:support@yoghurtofyouth.co.uk" class="underline hover:text-amber-500 transition">
            support@yoghurtofyouth.co.uk
          </a>
        </p>
        <p>
          📞 Phone:
          <a href="tel:+447756231844" class="underline hover:text-amber-500 transition">
            07756 231844
          </a>
        </p>
        <p class="text-xs text-slate-600">We aim to respond within one working day.</p>
      </div>

      <p class="mt-6 text-slate-700 text-sm leading-relaxed">
        You can also follow us on
        <a href="https://www.instagram.com/yoghurtofyouth" class="underline hover:text-amber-500 transition">Instagram</a>
        for updates, or browse the yoghurt in our
        <a href="/shop" class="underline hover:text-amber-500 transition">shop</a>.
      </p>

      <p>&nbsp</p>
      <p>&nbsp</p>
      <p>&nbsp</p>
      <p>&nbsp</p>
      <p>&nbsp</p>
      <p>&nbsp</p>
      <p>&nbsp</p>
