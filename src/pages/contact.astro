---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact Us | Yoghurt of Youth"
  description="Get in touch with Yoghurt of Youth. Email or call us for product advice, order support, or any questions about our live L. reuteri probiotic yoghurt."
>
  <section
    id="contact"
    class="relative scroll-mt-32 md:scroll-mt-24 text-white py-12"
    style="background-image: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.65)), url('/about_bg.webp'); background-size: cover; background-position: 50% center; background-repeat: no-repeat;"
  >
    <div class="max-w-3xl mx-auto px-8">
      <h1 class="text-2xl md:text-3xl font-bold text-white">
        Contact Us
      </h1>

      <p class="mt-4 text-white text-sm leading-relaxed">
        Have a question about our yoghurt or your order? We're always happy to help. Get in touch and we'll get back to
        you as soon as we can.
      </p>

      <div class="mt-6 space-y-2 text-white text-sm">
        <p>
          📧 Email:
          <a href="mailto:support@yoghurtofyouth.co.uk" class="underline hover:text-amber-300 transition">
            support@yoghurtofyouth.co.uk
          </a>
        </p>
        <p>
          📞 Phone:
          <a href="tel:+447756231844" class="underline hover:text-amber-300 transition">
            07756 231844
          </a>
        </p>
        <p class="text-xs text-white">We aim to respond within one working day.</p>
      </div>

      <p class="mt-6 text-white text-sm leading-relaxed">
        You can also follow us on
        <a href="https://www.instagram.com/yoghurtofyouth" class="underline hover:text-amber-300 transition">Instagram</a>
        for updates, or browse the yoghurt in our
        <a href="/shop" class="underline hover:text-amber-300 transition">shop</a>.
      </p>

      <p>&nbsp</p>
      <p>&nbsp</p>
      <p>&nbsp</p>
      <p>&nbsp</p>
      <p>&nbsp</p>
      <p>&nbsp</p>
      <p>&nbsp</p>
      <p>&nbsp</p>
      <p>&nbsp</p>
      <p>&nbsp</p>
